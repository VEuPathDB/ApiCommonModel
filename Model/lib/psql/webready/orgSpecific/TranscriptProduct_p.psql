DROP TABLE IF EXISTS :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp;

create unlogged table :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp as
(select t.na_feature_id
      , t.source_id
      , t.product
      , t.parent_id as gene_na_feature_id
      , gf.source_id as gene_source_id
      , o.genome_source
 from dots.transcript t
    , dots.genefeature gf
    , dots.nasequence nas
    , apidb.Organism o
 where t.parent_id = gf.na_feature_id
   and gf.na_sequence_id = nas.na_sequence_id
   and nas.taxon_id = :TAXON_ID
   and o.taxon_id = nas.taxon_id
)
;


:CREATE_AND_POPULATE
  WITH
    informative_tp AS (
      SELECT tp.na_feature_id, tp.product, tp.assigned_by, tp.is_preferred
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN apidb.TranscriptProduct tp ON tp.na_feature_id = t.na_feature_id
      WHERE tp.product IS NOT NULL
        AND TRIM(tp.product) != ''
        AND tp.product !~* '(hypothetical[_ ]protein|unspecified product|conserved hypothetical protein|predicted protein|protein of unknown function|uncharacterized protein|conserved protein,\s*unknown function|---na---|contig)'
        AND NOT (tp.product ~* '^has domain\(s\) with predicted' AND (tp.product LIKE '%,%' OR tp.product ~* ' and '))
        AND NOT (tp.product NOT LIKE '% %' AND tp.product LIKE 'XM%')
        AND tp.product !~ '^CAD\d+(\.\d+)?$'
        AND tp.product !~* 'conserved\s+\w+\s+protein,?\s*unknown\s+function'
        AND tp.product !~* 'uncharacterized\s+loc\d+'
        AND tp.product NOT LIKE 'CSON%'
        AND tp.product NOT LIKE 'hypothetical protein BGH%'
        AND tp.product NOT LIKE 'DEHA2A%'
        AND NOT (tp.product NOT LIKE '% %' AND (tp.product ~ '^[A-Z]{2,4}\d{4,}$' OR tp.product ~ '^[A-Z]{3,5}_\d+$' OR tp.product ~ '^LOC\d+$' OR tp.product ~ '^[A-Z]+\d+\.[0-9]+$'))
        AND tp.product NOT LIKE 'Similar to [%'
        AND tp.product NOT LIKE '%UniProtKB%'
        AND LOWER(TRIM(tp.product)) NOT IN ('protein', 'gene product', 'gene', 'orf')
    ),

    informative_gfp AS (
      SELECT gfp.na_feature_id AS gene_na_feature_id, gfp.product, gfp.assigned_by, gfp.is_preferred
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN apidb.GeneFeatureProduct gfp ON gfp.na_feature_id = t.gene_na_feature_id
      WHERE gfp.product IS NOT NULL
        AND TRIM(gfp.product) != ''
        AND gfp.product !~* '(hypothetical[_ ]protein|unspecified product|conserved hypothetical protein|predicted protein|protein of unknown function|uncharacterized protein|conserved protein,\s*unknown function|---na---|contig)'
        AND NOT (gfp.product ~* '^has domain\(s\) with predicted' AND (gfp.product LIKE '%,%' OR gfp.product ~* ' and '))
        AND NOT (gfp.product NOT LIKE '% %' AND gfp.product LIKE 'XM%')
        AND gfp.product !~ '^CAD\d+(\.\d+)?$'
        AND gfp.product !~* 'conserved\s+\w+\s+protein,?\s*unknown\s+function'
        AND gfp.product !~* 'uncharacterized\s+loc\d+'
        AND gfp.product NOT LIKE 'CSON%'
        AND gfp.product NOT LIKE 'hypothetical protein BGH%'
        AND gfp.product NOT LIKE 'DEHA2A%'
        AND NOT (gfp.product NOT LIKE '% %' AND (gfp.product ~ '^[A-Z]{2,4}\d{4,}$' OR gfp.product ~ '^[A-Z]{3,5}_\d+$' OR gfp.product ~ '^LOC\d+$' OR gfp.product ~ '^[A-Z]+\d+\.[0-9]+$'))
        AND gfp.product NOT LIKE 'Similar to [%'
        AND gfp.product NOT LIKE '%UniProtKB%'
        AND LOWER(TRIM(gfp.product)) NOT IN ('protein', 'gene product', 'gene', 'orf')
    ),

    informative_dt AS (
      SELECT t.na_feature_id, t.product, tmp.genome_source
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp tmp
      INNER JOIN dots.Transcript t ON t.na_feature_id = tmp.na_feature_id
      WHERE t.product IS NOT NULL
        AND TRIM(t.product) != ''
        AND t.product !~* '(hypothetical[_ ]protein|unspecified product|conserved hypothetical protein|predicted protein|protein of unknown function|uncharacterized protein|conserved protein,\s*unknown function|---na---|contig)'
        AND NOT (t.product ~* '^has domain\(s\) with predicted' AND (t.product LIKE '%,%' OR t.product ~* ' and '))
        AND NOT (t.product NOT LIKE '% %' AND t.product LIKE 'XM%')
        AND t.product !~ '^CAD\d+(\.\d+)?$'
        AND t.product !~* 'conserved\s+\w+\s+protein,?\s*unknown\s+function'
        AND t.product !~* 'uncharacterized\s+loc\d+'
        AND t.product NOT LIKE 'CSON%'
        AND t.product NOT LIKE 'hypothetical protein BGH%'
        AND t.product NOT LIKE 'DEHA2A%'
        AND NOT (t.product NOT LIKE '% %' AND (t.product ~ '^[A-Z]{2,4}\d{4,}$' OR t.product ~ '^[A-Z]{3,5}_\d+$' OR t.product ~ '^LOC\d+$' OR t.product ~ '^[A-Z]+\d+\.[0-9]+$'))
        AND t.product NOT LIKE 'Similar to [%'
        AND t.product NOT LIKE '%UniProtKB%'
        AND LOWER(TRIM(t.product)) NOT IN ('protein', 'gene product', 'gene', 'orf')
    ),

    informative_gf AS (
      SELECT DISTINCT tmp.gene_na_feature_id, gf.product, tmp.genome_source
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp tmp
      INNER JOIN dots.GeneFeature gf ON gf.na_feature_id = tmp.gene_na_feature_id
      WHERE gf.product IS NOT NULL
        AND TRIM(gf.product) != ''
        AND gf.product !~* '(hypothetical[_ ]protein|unspecified product|conserved hypothetical protein|predicted protein|protein of unknown function|uncharacterized protein|conserved protein,\s*unknown function|---na---|contig)'
        AND NOT (gf.product ~* '^has domain\(s\) with predicted' AND (gf.product LIKE '%,%' OR gf.product ~* ' and '))
        AND NOT (gf.product NOT LIKE '% %' AND gf.product LIKE 'XM%')
        AND gf.product !~ '^CAD\d+(\.\d+)?$'
        AND gf.product !~* 'conserved\s+\w+\s+protein,?\s*unknown\s+function'
        AND gf.product !~* 'uncharacterized\s+loc\d+'
        AND gf.product NOT LIKE 'CSON%'
        AND gf.product NOT LIKE 'hypothetical protein BGH%'
        AND gf.product NOT LIKE 'DEHA2A%'
        AND NOT (gf.product NOT LIKE '% %' AND (gf.product ~ '^[A-Z]{2,4}\d{4,}$' OR gf.product ~ '^[A-Z]{3,5}_\d+$' OR gf.product ~ '^LOC\d+$' OR gf.product ~ '^[A-Z]+\d+\.[0-9]+$'))
        AND gf.product NOT LIKE 'Similar to [%'
        AND gf.product NOT LIKE '%UniProtKB%'
        AND LOWER(TRIM(gf.product)) NOT IN ('protein', 'gene product', 'gene', 'orf')
    ),

    all_informative AS (
      SELECT t.source_id, itp.product, itp.assigned_by, itp.is_preferred, 'transcript' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN informative_tp itp ON itp.na_feature_id = t.na_feature_id
      UNION ALL
      SELECT t.source_id, igfp.product, igfp.assigned_by, igfp.is_preferred, 'gene' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN informative_gfp igfp ON igfp.gene_na_feature_id = t.gene_na_feature_id
      UNION ALL
      SELECT t.source_id, idt.product, idt.genome_source AS assigned_by, 0 AS is_preferred, 'transcript' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN informative_dt idt ON idt.na_feature_id = t.na_feature_id
      UNION ALL
      SELECT t.source_id, igf.product, igf.genome_source AS assigned_by, 0 AS is_preferred, 'gene' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN informative_gf igf ON igf.gene_na_feature_id = t.gene_na_feature_id
    ),

    all_noninformative AS (
      SELECT t.source_id, tp.product, tp.assigned_by, tp.is_preferred, 'transcript' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN apidb.TranscriptProduct tp ON tp.na_feature_id = t.na_feature_id
      WHERE tp.product IS NOT NULL AND TRIM(tp.product) != ''
      UNION ALL
      SELECT t.source_id, gfp.product, gfp.assigned_by, gfp.is_preferred, 'gene' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN apidb.GeneFeatureProduct gfp ON gfp.na_feature_id = t.gene_na_feature_id
      WHERE gfp.product IS NOT NULL AND TRIM(gfp.product) != ''
      UNION ALL
      SELECT t.source_id, dt.product, t.genome_source AS assigned_by, 0 AS is_preferred, 'transcript' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN dots.Transcript dt ON dt.na_feature_id = t.na_feature_id
      WHERE dt.product IS NOT NULL AND TRIM(dt.product) != ''
      UNION ALL
      SELECT t.source_id, dgf.product, t.genome_source AS assigned_by, 0 AS is_preferred, 'gene' AS source_type
      FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
      INNER JOIN dots.GeneFeature dgf ON dgf.na_feature_id = t.gene_na_feature_id
      WHERE dgf.product IS NOT NULL AND TRIM(dgf.product) != ''
    ),

    assigned_by_groups(assigned_by_val, group_name) AS (
      VALUES
        ('veupathdb',        'veupathdb'),
        ('apollo',           'apollo'),
        ('community',        'community'),
        ('anderssonlab',     'lab'),
        ('berna',            'lab'),
        ('beverleylab',      'lab'),
        ('corridalab',       'lab'),
        ('flegontovlab',     'lab'),
        ('franzen',          'lab'),
        ('fritzlab',         'lab'),
        ('hertzfowlerlab',   'lab'),
        ('jcarltonlab',      'lab'),
        ('kissingerlab',     'lab'),
        ('liverpool',        'lab'),
        ('lukeslab',         'lab'),
        ('mcbridelab',       'lab'),
        ('msu',              'lab'),
        ('painlab',          'lab'),
        ('requenalab',       'lab'),
        ('siegelab',         'lab'),
        ('siegellab',        'lab'),
        ('stukenbrocklab',   'lab'),
        ('tachezylab',       'lab'),
        ('tarletonlab',      'lab'),
        ('ubc',              'lab'),
        ('ulaval',           'lab'),
        ('valkiunaslab',     'lab'),
        ('wittwer',          'lab'),
        ('wittwerlab',       'lab'),
        ('yurchenkolab',     'lab'),
        ('dieterichlab',     'lab'),
        ('widmerlab',        'lab'),
        ('hammondkosacklab', 'lab'),
        ('parkinsonlab',     'lab'),
        ('saskatchewan',     'lab'),
        ('bochum',           'lab'),
        ('jcvi',             'genomedb'),
        ('jgi',              'genomedb'),
        ('sanger',           'genomedb'),
        ('pombase',          'genomedb'),
        ('dictybase',        'genomedb'),
        ('aspgd',            'genomedb'),
        ('cgd',              'genomedb'),
        ('sgd',              'genomedb'),
        ('genedb',           'genomedb'),
        ('broad',            'genomedb'),
        ('vectorbase',       'genomedb'),
        ('gemo',             'genomedb'),
        ('ensembl',          'ensembl'),
        ('uniprot',          'uniprot'),
        ('uniprotkb/trembl', 'uniprot'),
        ('uniprot/pfam',     'uniprot'),
        ('refseq',           'refseq'),
        ('entrezgene',       'entrezgene'),
        ('genbank',          'genbank'),
        ('gb',               'genbank'),
        ('pfam',             'pfam'),
        ('arba',             'arba')
    ),

    rule_lookup(group_name, is_preferred, source_type, source_rule, rule_description) AS (
      VALUES
        ('veupathdb',   1, 'transcript',  1,  'veupathdb_preferred_transcript'),
        ('apollo',      1, 'transcript',  2,  'apollo_preferred_transcript'),
        ('community',   1, 'transcript',  3,  'community_preferred_transcript'),
        ('lab',         1, 'transcript',  4,  'lab_preferred_transcript'),
        ('genomedb',    1, 'transcript',  5,  'genomedb_preferred_transcript'),
        ('ensembl',     1, 'transcript',  6,  'ensembl_preferred_transcript'),
        ('uniprot',     1, 'transcript',  7,  'uniprot_preferred_transcript'),
        ('refseq',      1, 'transcript',  8,  'refseq_preferred_transcript'),
        ('entrezgene',  1, 'transcript',  9,  'entrezgene_preferred_transcript'),
        ('genbank',     1, 'transcript', 10,  'genbank_preferred_transcript'),
        ('pfam',        1, 'transcript', 11,  'pfam_preferred_transcript'),
        ('veupathdb',   0, 'transcript', 12,  'veupathdb_transcript'),
        ('apollo',      0, 'transcript', 13,  'apollo_transcript'),
        ('community',   0, 'transcript', 14,  'community_transcript'),
        ('lab',         0, 'transcript', 15,  'lab_transcript'),
        ('genomedb',    0, 'transcript', 16,  'genomedb_transcript'),
        ('ensembl',     0, 'transcript', 17,  'ensembl_transcript'),
        ('uniprot',     0, 'transcript', 18,  'uniprot_transcript'),
        ('refseq',      0, 'transcript', 19,  'refseq_transcript'),
        ('entrezgene',  0, 'transcript', 20,  'entrezgene_transcript'),
        ('genbank',     0, 'transcript', 21,  'genbank_transcript'),
        ('pfam',        0, 'transcript', 22,  'pfam_transcript'),
        ('veupathdb',   1, 'gene',       23,  'veupathdb_preferred_gene'),
        ('apollo',      1, 'gene',       24,  'apollo_preferred_gene'),
        ('community',   1, 'gene',       25,  'community_preferred_gene'),
        ('lab',         1, 'gene',       26,  'lab_preferred_gene'),
        ('genomedb',    1, 'gene',       27,  'genomedb_preferred_gene'),
        ('ensembl',     1, 'gene',       28,  'ensembl_preferred_gene'),
        ('uniprot',     1, 'gene',       29,  'uniprot_preferred_gene'),
        ('refseq',      1, 'gene',       30,  'refseq_preferred_gene'),
        ('entrezgene',  1, 'gene',       31,  'entrezgene_preferred_gene'),
        ('genbank',     1, 'gene',       32,  'genbank_preferred_gene'),
        ('pfam',        1, 'gene',       33,  'pfam_preferred_gene'),
        ('veupathdb',   0, 'gene',       34,  'veupathdb_gene'),
        ('apollo',      0, 'gene',       35,  'apollo_gene'),
        ('community',   0, 'gene',       36,  'community_gene'),
        ('lab',         0, 'gene',       37,  'lab_gene'),
        ('genomedb',    0, 'gene',       38,  'genomedb_gene'),
        ('ensembl',     0, 'gene',       39,  'ensembl_gene'),
        ('uniprot',     0, 'gene',       40,  'uniprot_gene'),
        ('refseq',      0, 'gene',       41,  'refseq_gene'),
        ('entrezgene',  0, 'gene',       42,  'entrezgene_gene'),
        ('genbank',     0, 'gene',       43,  'genbank_gene'),
        ('pfam',        0, 'gene',       44,  'pfam_gene'),
        ('arba',        0, 'gene',       46,  'arba_gene'),
        ('arba',        1, 'gene',       46,  'arba_gene')
    ),

    all_products AS (
      SELECT ai.source_id,
             SUBSTR(STRING_AGG(DISTINCT ai.product, ', ' ORDER BY ai.product), 1, 4000) AS product,
             rl.source_rule,
             COUNT(DISTINCT ai.product) AS value_count,
             rl.rule_description
      FROM all_informative ai
      INNER JOIN assigned_by_groups abg ON abg.assigned_by_val = LOWER(ai.assigned_by)
      INNER JOIN rule_lookup rl ON rl.group_name = abg.group_name
                               AND rl.is_preferred = ai.is_preferred
                               AND rl.source_type = ai.source_type
      GROUP BY ai.source_id, rl.source_rule, rl.rule_description
      HAVING COUNT(DISTINCT ai.product) = 1
      UNION ALL
      SELECT ai.source_id,
             SUBSTR(STRING_AGG(DISTINCT ai.product, ', ' ORDER BY ai.product), 1, 4000) AS product,
             45                                                                            AS source_rule,
             COUNT(DISTINCT ai.product)                                                    AS value_count,
             'blank_assigned_by'                                                           AS rule_description
      FROM all_informative ai
      WHERE (ai.assigned_by IS NULL OR TRIM(ai.assigned_by) = '')
      GROUP BY ai.source_id
      HAVING COUNT(DISTINCT ai.product) = 1
      UNION ALL
      SELECT ani.source_id,
             SUBSTR(STRING_AGG(DISTINCT ani.product, ', ' ORDER BY ani.product), 1, 4000) AS product,
             rl.source_rule + 47,
             COUNT(DISTINCT ani.product)                                                    AS value_count,
             rl.rule_description || '_uninformative'
      FROM all_noninformative ani
      INNER JOIN assigned_by_groups abg ON abg.assigned_by_val = LOWER(ani.assigned_by)
      INNER JOIN rule_lookup rl ON rl.group_name = abg.group_name
                               AND rl.is_preferred = ani.is_preferred
                               AND rl.source_type = ani.source_type
      GROUP BY ani.source_id, rl.source_rule, rl.rule_description
      HAVING COUNT(DISTINCT ani.product) = 1
      UNION ALL
      SELECT ani.source_id,
             SUBSTR(STRING_AGG(DISTINCT ani.product, ', ' ORDER BY ani.product), 1, 4000) AS product,
             92                                                                             AS source_rule,
             COUNT(DISTINCT ani.product)                                                    AS value_count,
             'blank_assigned_by_uninformative'                                              AS rule_description
      FROM all_noninformative ani
      WHERE (ani.assigned_by IS NULL OR TRIM(ani.assigned_by) = '')
      GROUP BY ani.source_id
      HAVING COUNT(DISTINCT ani.product) = 1
    ),

    ranked_products AS (
      SELECT source_id, product, source_rule, value_count, rule_description,
             ROW_NUMBER() OVER (PARTITION BY source_id ORDER BY source_rule) as rank
      FROM all_products
    )
  SELECT t.source_id,
         COALESCE(rp.product, 'unspecified product') as product,
         COALESCE(rp.value_count, 0) as value_count,
         COALESCE(rp.source_rule, 94) as source_rule,
         COALESCE(rp.rule_description, 'unspecified') as source_rule_description,
         ':PROJECT_ID' as project_id,
         ':ORG_ABBREV' as org_abbrev,
         current_timestamp as modification_date
  FROM :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp t
  LEFT JOIN ranked_products rp ON t.source_id = rp.source_id AND rp.rank = 1;
:DECLARE_PARTITION;


delete from :SCHEMA.TranscriptProduct_p  where product is null and org_abbrev = ':ORG_ABBREV';

drop table :SCHEMA.:CLEAN_ORG_ABBREVTranscriptProductTmp
;
